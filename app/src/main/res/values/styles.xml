<resources>
    <style name="AppTheme" parent="android:style/Theme.Material.Light.NoActionBar">
        <item name="android:windowNoTitle">true</item>
        <item name="android:windowActionBar">false</item>
        <item name="android:windowLightStatusBar">true</item>
        <item name="android:windowLightNavigationBar">true</item>
        <item name="android:fontFamily">sans</item>
        <item name="android:colorAccent">@color/theme_accent</item>
        <item name="android:textCursorDrawable">@drawable/text_cursor_accent</item>
        <item name="android:windowDrawsSystemBarBackgrounds">true</item>
        <item name="android:statusBarColor">@android:color/transparent</item>
        <item name="android:navigationBarColor">@android:color/transparent</item>
        <item name="android:enforceStatusBarContrast">false</item>
        <item name="android:enforceNavigationBarContrast">false</item>
    </style>

    <style name="BottomSheetDialogAnimation">
        <!--
          Keep these names alphabetically after the established slide_* and stay resources.
          Android 14 can retain window-animation resource IDs across an in-place install, so
          inserting an earlier anim name makes existing page transitions resolve incorrectly.
        -->
        <item name="android:windowEnterAnimation">@anim/window_sheet_slide_in_bottom</item>
        <item name="android:windowExitAnimation">@anim/window_sheet_slide_out_bottom</item>
    </style>
</resources>
